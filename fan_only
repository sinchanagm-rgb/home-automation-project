#define RELAY_PIN 22
#define LED_PIN 26

void setup() {
  Serial.begin(115200);
  pinMode(RELAY_PIN, OUTPUT);
  pinMode(LED_PIN, OUTPUT);
  digitalWrite(RELAY_PIN, HIGH); // relay off at start (HIGH = OFF for relay)
  digitalWrite(LED_PIN, LOW);    // light off at start
}

void loop() {
  if (Serial.available()) {
    char data = Serial.read();
    if (data == '1') {
      digitalWrite(LED_PIN, HIGH);  // Light ON
    }
    else if (data == '2') {
      digitalWrite(LED_PIN, LOW);   // Light OFF
    }
    else if (data == '3') {
      digitalWrite(RELAY_PIN, LOW); // Fan ON
    }
    else if (data == '4') {
      digitalWrite(RELAY_PIN, HIGH); // Fan OFF
    }
  }
}/////////arduino code




